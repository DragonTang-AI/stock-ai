import os
import httpx
from typing import AsyncGenerator, Optional
import logging

logger = logging.getLogger(__name__)


def _get_deepseek_config():
    """延迟读取环境变量（避免模块导入时读取）"""
    api_key = os.environ.get("DEEPSEEK_API_KEY") or os.getenv("DEEPSEEK_API_KEY")
    api_url = os.environ.get("DEEPSEEK_API_URL") or os.getenv("DEEPSEEK_API_URL") or "https://api.deepseek.com/v1"
    model = os.environ.get("DEEPSEEK_MODEL") or os.getenv("DEEPSEEK_MODEL") or "deepseek-v4-flash"
    
    logger.info(f"DeepSeek config loaded: URL={api_url}, Model={model}, Key={'set' if api_key else 'NOT SET'}")
    
    return {
        "api_key": api_key,
        "api_url": api_url,
        "model": model
    }


async def chat_completion(
    messages: list[dict],
    model: Optional[str] = None,
    temperature: float = 0.7,
    stream: bool = False
) -> str:
    """调用 DeepSeek API 生成回复"""
    config = _get_deepseek_config()
    if not config["api_key"]:
        raise ValueError("DEEPSEEK_API_KEY not configured")
    
    url = f"{config['api_url']}/chat/completions"
    headers = {
        "Authorization": f"Bearer {config['api_key']}",
        "Content-Type": "application/json"
    }
    payload = {
        "model": model or config["model"],
        "messages": messages,
        "temperature": temperature,
        "stream": stream
    }
    
    async with httpx.AsyncClient(timeout=30.0) as client:
        response = await client.post(url, headers=headers, json=payload)
        response.raise_for_status()
        data = response.json()
        return data["choices"][0]["message"]["content"]


async def generate_advisor_response(
    question: str,
    portfolio_context: dict,
    market_temperature: dict
) -> str:
    """生成投资助手回复"""
    logger.info(f"generate_advisor_response called with question: {question}")
    
    system_prompt = """你是 AI-Stock 智能投资助手，基于用户持仓和大盘数据提供专业分析。

规则：
1. 用中文回答，专业但易懂
2. 基于提供的数据分析，不编造信息
3. 给出具体可操作的建议
4. 最后加上风险提示"""

    positions = portfolio_context.get('positions', [])
    risks = portfolio_context.get('risks', [])
    suggestions = portfolio_context.get('suggestions', [])
    summary = portfolio_context.get('summary', {})
    
    positions_str = _format_positions(positions)
    risks_str = _format_risks(risks)
    suggestions_str = _format_suggestions(suggestions)
    
    user_prompt = f"""用户问题：{question}

用户持仓概况：
- 总资产：{summary.get('total_equity', 'N/A')}
- 持仓数量：{summary.get('position_count', 0)} 只
- 胜率：{summary.get('win_rate', 0)}%
- 现金比例：{summary.get('cash_ratio', 0)}%

持仓详情：
{positions_str}

风险提醒：
{risks_str}

操作建议：
{suggestions_str}

大盘温度：{market_temperature.get('temperature_text', 'N/A')} ({market_temperature.get('avg_change_pct', 0)}%)

请回答用户问题。"""

    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": user_prompt}
    ]
    
    return await chat_completion(messages)


def _format_positions(positions: list) -> str:
    if not positions:
        return "无持仓"
    lines = []
    for p in positions:
        lines.append(f"- {p.get('name')} ({p.get('symbol')}): {p.get('profit_pct', 0):.2f}%, 评级：{p.get('rating_text', 'N/A')}")
    return "\n".join(lines)


def _format_risks(risks: list) -> str:
    if not risks:
        return "无风险提醒"
    lines = []
    for r in risks:
        lines.append(f"- [{r.get('level', 'info')}] {r.get('title')}: {r.get('desc', '')}")
    return "\n".join(lines)


def _format_suggestions(suggestions: list) -> str:
    if not suggestions:
        return "无操作建议"
    lines = []
    for s in suggestions:
        lines.append(f"- [{s.get('priority', 'low')}] {s.get('text')}: {s.get('reason', '')}")
    return "\n".join(lines)
