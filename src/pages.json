  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "AI-Stock",
    "navigationBarBackgroundColor": "#1A1A2E",
    "backgroundColor": "#F5F5F7",
    "animationType": "slide-in-right",
    "animationDuration": 250,
    "app-plus": {
      "background": "#F5F5F7",
      "safearea": {
        "bottom": { "offset": "auto" },
        "top": { "offset": "auto" },
        "left": { "offset": "auto" },
        "right": { "offset": "auto" }
      },
      "softinputMode": "adjustResize",
      "softinputNavBar": "none",
      "popGesture": "none",
      "bounce": "none"
    }
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#4A90E2",
    "borderStyle": "black",
    "backgroundColor": "#FFFFFF",
    "animation": true,
    "list": [
      {
        "pagePath": "pages/market/index",
        "text": "行情",
        "iconPath": "static/tabbar/market.png",
        "selectedIconPath": "static/tabbar/market-active.png"
      },
      {
        "pagePath": "pages/agent-market/index",
        "text": "交易员",
        "iconPath": "static/tabbar/selection.png",
        "selectedIconPath": "static/tabbar/selection-active.png"
      },
      {
        "pagePath": "pages/selection/index",
        "text": "选股",
        "iconPath": "static/tabbar/selection.png",
        "selectedIconPath": "static/tabbar/selection-active.png"
      },
      {
        "pagePath": "pages/portfolio/index",
        "text": "持仓",
        "iconPath": "static/tabbar/portfolio.png",
        "selectedIconPath": "static/tabbar/portfolio-active.png"
      },
      {
        "pagePath": "pages/advisor/index",
        "text": "AI助手",
        "iconPath": "static/tabbar/advisor.png",
        "selectedIconPath": "static/tabbar/advisor-active.png"
      },
      {
        "pagePath": "pages/mine/index",
        "text": "我的",
        "iconPath": "static/tabbar/mine.png",
        "selectedIconPath": "static/tabbar/mine-active.png"
      }
    ]
  },
  "preloadRule": {
    "pages/login/index": {
      "network": "all",
      "packages": ["pages/market/index", "pages/selection/index"]
    },
    "pages/market/index": {
      "network": "all",
      "packages": ["pages/selection/index", "pages/portfolio/index"]
    },
    "pages/selection/index": {
      "network": "all",
      "packages": ["pages/market/index", "pages/selection/detail"]
    },
    "pages/portfolio/index": {
      "network": "wifi",
      "packages": ["pages/portfolio/analytics"]
    }
  }
}
