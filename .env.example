# FastAPI 应用
APP_NAME=AI-Stock
APP_VERSION=0.1.0
APP_DESCRIPTION=A股+港股 AI 选股助手 + 模拟交易平台
DEBUG=true
IS_AUDIT_MODE=true

# 服务器
HOST=0.0.0.0
PORT=8000

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_stock
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_32_char_minimum_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM
LLM_PRIMARY_API_KEY=your_anthropic_api_key
LLM_PRIMARY_MODEL=claude-sonnet-4-20250514
LLM_BACKUP_API_KEY=your_deepseek_api_key
LLM_BACKUP_MODEL=deepseek-chat

# 数据源
AKSHARE_CACHE_TTL=300

# 风控（V1 模拟盘）
MAX_POSITION_PCT=0.15
DAILY_LOSS_CIRCUIT_PCT=0.05
